NODE_ENV=development
PORT=5003
MONGOURI=mongodb+srv://usuario:senha@cluster.mongodb.net/socialcof
JWT_SECRET=coloque_uma_string_aleatoria_longa_aqui
JWT_REFRESH_SECRET=coloque_outra_string_aleatoria_longa_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173,https://socialcof.grupomedcof.com.br

# Apify — scraping de Instagram e TikTok
INSTAGRAM_APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxx
TIKTOK_APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxx

# OpenAI — GPT e Whisper
GPT_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# AWS S3 — armazenamento de imagens e vídeos
AWS_S3_BUCKET=nome-do-seu-bucket
AWS_REGION=us-east-1

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com

# Agendamentos (cron)
TIKTOK_CRON_SCHEDULE="0 */4 * * *"
NEWS_RSS_CRON_SCHEDULE="0 */2 * * *"
